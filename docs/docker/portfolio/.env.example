# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
APP_NAME=http-server
APP_VERSION=2.1.1
ENV=development
SERVER_HEADER=ZeroDayZ7
PORT=9000
WORKER_PORT=9001
CONFIG_SOURCE=auto

# Performance & Routing
PREFORK=false
CASE_SENSITIVE=true
STRICT_ROUTING=true
BODY_LIMIT_MB=2

# Timeouts
IDLE_TIMEOUT_SEC=30
READ_TIMEOUT_SEC=5
WRITE_TIMEOUT_SEC=10
SHUTDOWN_TIMEOUT_SEC=5

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# MongoDB
MONGO_ROOT_USER=admin
MONGO_DATABASE=zero_day_db

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=portfolio_db
MYSQL_USER=user_app

# Connection Pool
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MIN=30

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ==============================================================================
# SECURITY & NETWORKING
# ==============================================================================
# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_METHODS=GET,POST,OPTIONS,PUT,DELETE
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SEC=60

# Docker
COMPOSE_PROJECT_NAME=portfolio

# Telemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317

# Workers
WORKER_FLUSH_INTERVAL=10s